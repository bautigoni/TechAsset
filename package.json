{
  "name": "techasset-nfs-react-node",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "concurrently -k \"npm run server\" \"vite --host 0.0.0.0\"",
    "dev:full": "concurrently -k -n server,vite,tunnel \"npm run server\" \"vite --host 0.0.0.0\" \"node scripts/start-tunnel.js\"",
    "server": "node server/index.js",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "tunnel": "node scripts/start-tunnel.js",
    "serve": "concurrently -k -n server,tunnel \"node server/index.js\" \"node scripts/start-tunnel.js\"",
    "db:init": "node server/db/seed.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "better-sqlite3": "^11.9.1",
    "concurrently": "^9.1.2",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "localtunnel": "^2.0.2",
    "mammoth": "^1.12.0",
    "nodemailer": "^6.9.16",
    "openai": "^6.35.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "typescript": "^5.7.3",
    "vite": "^6.1.0"
  }
}
