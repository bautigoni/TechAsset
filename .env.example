PORT=8000
APP_NAME=TechAsset - NFS
SITE_CODE=NFPT

# Lectura del padrón de equipos. Vacío = usar /sheet.csv local desde la app.
GOOGLE_SHEET_CSV_URL=/sheet.csv
APPS_SCRIPT_URL=
APPS_SCRIPT_INVENTORY_URL=
SHEET_CACHE_TTL_MS=5000
SHEET_FETCH_TIMEOUT_MS=4500

# Persistencia local (montar ./data como volumen en Docker)
SQLITE_DB_PATH=./data/techasset.db
CACHE_CSV_PATH=./data/cache_sheet.csv
DEVICES_APP_CSV_PATH=./data/devices_app.csv

AUTO_REFRESH_SECONDS=5

# === Herramientas auxiliares ===
TOOLS_TEMP_DIR=./data/tmp
MAX_UPLOAD_MB=10

# Envío de credenciales 365 (SMTP). Estos valores quedan como fallback;
# la app los puede sobreescribir desde la UI y los persiste en SQLite.
SMTP_SERVER=
SMTP_PORT=
SMTP_USER=
SMTP_APP_PASSWORD=
MAIL_FROM=
MAIL_SUBJECT=Credenciales de acceso
MODO_PRUEBA=true
MICROSOFT_LOGIN_URL=

# Accesos rápidos institucionales
HANDING_TICKET_URL=

# IA / asistente (opcional, dejar vacío en producción si no se usa)
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_PROMPT_ID=

# Localtunnel (no se usa en Docker / VPS)
LOCALTUNNEL_SUBDOMAIN=techasset-nfpt
