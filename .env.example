PORT=8000
APP_NAME=TechAsset
# URL base pública usada en links de los mails (registros, aprobaciones, etc.)
# En producción: https://techasset.tu-dominio
APP_BASE_URL=http://127.0.0.1:8000
DEFAULT_SITE_CODE=NFPT
BOOTSTRAP_SITES=NFPT:Northfield Puertos,NFND:Northfield Nordelta
AUTH_ALLOWED_EMAILS=admin@northfield.local

# Base local SQLite. Es la fuente principal de verdad.
SQLITE_DB_PATH=./data/techasset.db

# Importación manual opcional desde CSV publicado. No se usa para sincronización viva.
GOOGLE_SHEET_CSV_URL=
CACHE_CSV_PATH=./data/cache_sheet.csv
DEVICES_APP_CSV_PATH=./data/devices_app.csv

AUTO_REFRESH_SECONDS=5

# Herramientas auxiliares
TOOLS_TEMP_DIR=./data/tmp
MAX_UPLOAD_MB=10

# Notificaciones administrativas (registros, aprobaciones, etc.)
SUPERADMIN_EMAILS=bautistagoni@northfield.edu.ar,techassetbot@gmail.com

# SMTP / Bot de mail (Gmail con contraseña de aplicación)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=techassetbot@gmail.com
SMTP_APP_PASSWORD=
MAIL_FROM=TechAsset Bot <techassetbot@gmail.com>
MAIL_SUBJECT=Credenciales de acceso
# MODO_PRUEBA=true loguea pero NO envía. Pasar a false en producción.
MODO_PRUEBA=true
MICROSOFT_LOGIN_URL=

# Accesos rápidos institucionales
HANDING_TICKET_URL=https://northfield-puertos.handing.co/formulario/solicitar-mantenimiento